# NCBI E-utilities credentials. Create a key at:
# https://account.ncbi.nlm.nih.gov/settings/  (API Key Management)
# With a key NCBI allows 10 req/s; without, 3 req/s.
NCBI_API_KEY=

# Contact email sent with every E-utilities request (required by NCBI usage policy).
NCBI_CONTACT_EMAIL=you@example.com
