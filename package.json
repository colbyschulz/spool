{
  "name": "spool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["shared", "apps/*"],
  "scripts": {
    "build": "npm run build -w @spool/web",
    "dev:server": "npm run dev -w @spool/server",
    "dev:web": "npm run dev -w @spool/web",
    "lint": "eslint .",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  }
}
